<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wallpapers — Moonoi Monsoon</title>
<meta name="description" content="Free world-building wallpapers by Moonoi Monsoon.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Silkscreen:wght@400;700&family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --blue:#4aa8e8;--blue-hi:#8dd4ff;--blue-lo:#2a7ab8;
    --navy:#0a1220;--navy-2:#0f1a2a;--navy-card:#0c1622;
    --cream:#d8eef8;--cream-dim:#8ab0cc;
    --ring:rgba(74,168,232,.5);
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
  html{scroll-behavior:smooth;background:#060e18}
  body{
    font-family:'Prompt',system-ui,sans-serif;
    background:
      radial-gradient(120% 80% at 50% -10%, rgba(74,168,232,.07) 0%, transparent 42%),
      radial-gradient(70% 50% at 22% 8%, rgba(74,168,232,.05) 0%, transparent 55%),
      linear-gradient(180deg,#0f1a2a 0%,#0c1520 38%,#081018 78%,#060e18 100%);
    background-color:#060e18;
    color:var(--cream);
    min-height:100dvh;
    overflow-x:hidden;
  }
  /* moonlight glow */
  body::after{
    content:"";position:fixed;left:50%;top:-10%;transform:translateX(-50%);
    width:100%;height:50%;pointer-events:none;z-index:0;
    background:radial-gradient(50% 60% at 50% 0%,rgba(74,168,232,.08) 0%,transparent 70%);
    mix-blend-mode:screen;animation:moonGlow 8s ease-in-out infinite;
  }
  @keyframes moonGlow{0%,100%{opacity:.6}50%{opacity:1}}
  body::before{
    content:"";position:fixed;inset:0;pointer-events:none;z-index:0;
    background:repeating-linear-gradient(0deg,rgba(74,168,232,.018) 0 2px,transparent 2px 4px);
    mix-blend-mode:screen;opacity:.5;
  }

  /* ===== Blue embers / sparks ===== */
  .embers{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden}
  .ember{
    position:absolute;bottom:-10px;border-radius:50%;
    background:#4aa8e8;opacity:0;
    box-shadow:0 0 5px 1px rgba(74,168,232,.6);
    animation:riseBlue linear infinite;
  }
  .ember.spark{
    background:#a8d8f0;
    box-shadow:0 0 7px 2px rgba(168,216,240,.7);
  }
  @keyframes riseBlue{
    0%{transform:translateY(0) translateX(0) scale(1);opacity:0}
    8%{opacity:.85}
    70%{opacity:.6}
    100%{transform:translateY(-104vh) translateX(var(--drift,12px)) scale(.4);opacity:0}
  }
  @media(prefers-reduced-motion:reduce){
    body::after{animation:none}
    .embers{display:none}
  }

  .wrap{position:relative;z-index:1;max-width:600px;margin:0 auto;padding:38px 20px 60px}

  /* ===== Hero ===== */
  .hero{text-align:center;padding:14px 0 20px}
  .back-link{
    display:inline-flex;align-items:center;gap:7px;margin-bottom:28px;
    font-family:'Silkscreen',monospace;font-size:10px;letter-spacing:.08em;
    text-transform:uppercase;color:var(--cream-dim);text-decoration:none;
    transition:color .14s;
  }
  .back-link:hover{color:var(--blue-hi)}
  .back-link svg{width:14px;height:14px}
  .logo-badge{
    width:80px;height:80px;margin:0 auto 18px;border-radius:22px;
    background:var(--navy-2);display:grid;place-items:center;
    box-shadow:0 0 0 1px rgba(74,168,232,.18),0 12px 32px rgba(0,0,0,.5);
  }
  .logo-badge svg{width:48px;height:48px}
  .brand-name{
    font-family:'Silkscreen',monospace;font-weight:700;
    font-size:11px;letter-spacing:.14em;color:var(--blue);opacity:.85;
    text-transform:uppercase;margin-bottom:16px;
  }
  .title{
    font-family:'Silkscreen',monospace;font-weight:700;
    font-size:clamp(22px,6vw,32px);line-height:1.15;
    color:var(--blue-hi);text-shadow:0 0 20px rgba(74,168,232,.4);
    margin-bottom:10px;
  }
  .subtitle{font-size:14px;color:var(--cream-dim);font-weight:300;line-height:1.6;max-width:32ch;margin:0 auto;}

  .px-rule{display:flex;gap:5px;justify-content:center;margin:22px 0 26px;}
  .px-rule i{width:7px;height:7px;background:var(--blue);opacity:.85;border-radius:1px}
  .px-rule i:nth-child(even){background:var(--blue-lo);opacity:.6}

  /* ===== Grid ===== */
  .grid{display:flex;flex-direction:column;gap:20px}

  .wp-card{
    background:linear-gradient(180deg,var(--navy-2),var(--navy-card));
    border:1px solid rgba(74,168,232,.18);
    border-radius:20px;overflow:hidden;
    transition:transform .14s,border-color .14s,box-shadow .14s;
  }
  .wp-card:hover{
    transform:translateY(-2px);
    border-color:rgba(74,168,232,.4);
    box-shadow:0 12px 32px rgba(0,0,0,.5),0 0 0 1px rgba(74,168,232,.1);
  }

  /* preview */
  .wp-preview{
    width:100%;aspect-ratio:4/3;
    position:relative;overflow:hidden;
    background:#0a1220;
  }
  .wp-preview img{
    width:100%;height:100%;object-fit:cover;
    display:block;
    transition:transform .4s ease;
  }
  .wp-card:hover .wp-preview img{transform:scale(1.02)}
  .wp-overlay{
    position:absolute;inset:0;
    background:linear-gradient(180deg,transparent 40%,rgba(6,14,24,.75) 100%);
    pointer-events:none;
  }
  .wp-label{
    position:absolute;bottom:12px;left:14px;
    font-family:'Silkscreen',monospace;font-size:9px;letter-spacing:.1em;
    color:rgba(168,216,240,.7);text-transform:uppercase;
  }
  .wp-res{
    position:absolute;bottom:12px;right:14px;
    font-family:'Silkscreen',monospace;font-size:9px;letter-spacing:.06em;
    color:rgba(168,216,240,.45);
  }

  /* info row */
  .wp-info{display:flex;align-items:center;gap:14px;padding:14px 16px;}
  .wp-body{flex:1 1 auto;min-width:0}
  .wp-title{display:block;font-family:'Prompt',sans-serif;font-weight:600;font-size:16px;color:var(--cream);line-height:1.25;}
  .wp-sub{display:block;margin-top:3px;font-size:12px;color:var(--cream-dim);font-weight:300;line-height:1.4;}
  .wp-tags{margin-top:8px;display:flex;gap:6px;flex-wrap:wrap}
  .tag{
    font-family:'Silkscreen',monospace;font-size:9px;letter-spacing:.05em;text-transform:uppercase;
    padding:4px 7px;border-radius:6px;
    background:rgba(74,168,232,.12);color:var(--blue-hi);
    border:1px solid rgba(74,168,232,.22);
  }
  .tag.sub{background:rgba(168,216,240,.07);color:var(--cream-dim);border-color:rgba(168,216,240,.14);}
  .dl-btn{
    flex:0 0 auto;display:inline-flex;align-items:center;justify-content:center;gap:7px;
    font-family:'Prompt',sans-serif;font-weight:500;font-size:13px;
    color:#fff;background:var(--blue);border:none;border-radius:12px;
    padding:10px 16px;cursor:pointer;text-decoration:none;white-space:nowrap;
    box-shadow:0 4px 14px rgba(74,168,232,.3);
    transition:background .14s,transform .1s,box-shadow .14s;
  }
  .dl-btn:hover{background:var(--blue-hi);color:var(--navy);transform:translateY(-1px);box-shadow:0 6px 18px rgba(74,168,232,.4);}
  .dl-btn:active{transform:translateY(0)}
  .dl-btn svg{width:14px;height:14px;flex:0 0 auto}

  /* ===== Footer ===== */
  footer{margin-top:40px;text-align:center;font-size:12px;color:var(--cream-dim);font-weight:300;line-height:1.7;}
  footer .made{font-family:'Silkscreen',monospace;font-size:10px;letter-spacing:.1em;color:var(--blue);opacity:.8;margin-bottom:8px;}
  .social{display:flex;justify-content:center;gap:14px;margin-bottom:16px}
  .social a{width:44px;height:44px;border-radius:13px;display:grid;place-items:center;background:rgba(74,168,232,.08);border:1px solid rgba(74,168,232,.22);color:var(--blue);text-decoration:none;transition:transform .15s,background .15s,box-shadow .15s;}
  @media(hover:hover){.social a:hover{transform:translateY(-2px);background:var(--blue);color:#fff;box-shadow:0 8px 22px rgba(74,168,232,.3);}}
  .social a:active{background:var(--blue);color:#fff;}
  .social svg{width:22px;height:22px;display:block}
  footer .handle{font-family:'Silkscreen',monospace;font-size:10px;letter-spacing:.04em;color:var(--blue);opacity:.85;margin-bottom:12px;}

  @media(prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important}}
</style>
</head>
<body>
<div class="embers" id="embers" aria-hidden="true"></div>
<div class="wrap">

  <header class="hero">
    <a class="back-link" href="https://moonoimonsoon.github.io">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M10 3L5 8l5 5"/></svg>
      moonoimonsoon.github.io
    </a>
    <div class="logo-badge" aria-hidden="true">
      <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g stroke-linecap="round" stroke-linejoin="round" fill="none" stroke-width="11">
          <path d="M16 76 V36 L33 58 L50 36 V76" stroke="#4aa8e8"/>
          <path d="M50 76 V36 L67 58 L84 36 V76" stroke="#8dd4ff"/>
        </g>
      </svg>
    </div>
    <div class="brand-name">Moonoi Monsoon</div>
    <h1 class="title">Wallpapers</h1>
    <p class="subtitle">World-building wallpapers from the forest workshop. Free to download.</p>
  </header>

  <div class="px-rule" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div>

  <div class="grid">

    <!-- Wallpaper 1: Daytime Forest (green) -->
    <div class="wp-card">
      <div class="wp-preview">
        <img src="wp_green.png" alt="Moonoi Monsoon — Forest Workshop (day)" loading="lazy">
        <div class="wp-overlay"></div>
        <span class="wp-label">Forest Workshop · Day</span>
        <span class="wp-res">1448×1086</span>
      </div>
      <div class="wp-info">
        <div class="wp-body">
          <span class="wp-title">Forest Workshop · Day</span>
          <span class="wp-sub">Sunlight through the canopy. The forge at work.</span>
          <div class="wp-tags">
            <span class="tag">FREE</span>
            <span class="tag sub">Wallpaper</span>
          </div>
        </div>
        <a class="dl-btn" href="wp_green.png" download="moonoimonsoon_forest_day.png">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="2" x2="8" y2="11"/><polyline points="4,7 8,12 12,7"/><line x1="2" y1="14" x2="14" y2="14"/></svg>
          Download
        </a>
      </div>
    </div>

    <!-- Wallpaper 2: Night Forest (blue) -->
    <div class="wp-card">
      <div class="wp-preview">
        <img src="wp_blue.png" alt="Moonoi Monsoon — Forest Workshop (night)" loading="lazy">
        <div class="wp-overlay"></div>
        <span class="wp-label">Forest Workshop · Night</span>
        <span class="wp-res">1446×1088</span>
      </div>
      <div class="wp-info">
        <div class="wp-body">
          <span class="wp-title">Forest Workshop · Night</span>
          <span class="wp-sub">Moonlit forest. Quiet river. The workshop glows.</span>
          <div class="wp-tags">
            <span class="tag">FREE</span>
            <span class="tag sub">Wallpaper</span>
          </div>
        </div>
        <a class="dl-btn" href="wp_blue.png" download="moonoimonsoon_forest_night.png">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="2" x2="8" y2="11"/><polyline points="4,7 8,12 12,7"/><line x1="2" y1="14" x2="14" y2="14"/></svg>
          Download
        </a>
      </div>
    </div>

  </div>

  <footer>
    <div class="made">หมูน้อย · little pig</div>
    <div class="social">
      <a href="https://www.instagram.com/moonoi_monsoon" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5.4" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><circle cx="17.4" cy="6.6" r="1.4" fill="currentColor"/></svg>
      </a>
      <a href="https://moonoimonsoon.github.io" target="_blank" rel="noopener noreferrer" aria-label="Moonoi Monsoon hub">
        <svg viewBox="0 0 100 100" fill="none"><g stroke-linecap="round" stroke-linejoin="round" fill="none" stroke="currentColor" stroke-width="11"><path d="M16 76 V36 L33 58 L50 36 V76"/><path d="M50 76 V36 L67 58 L84 36 V76"/></g></svg>
      </a>
    </div>
    <div class="handle">@moonoi_monsoon</div>
    Made by Moonoi Monsoon · Free to use, not to resell.
  </footer>

</div>

<script>
  // Blue embers rising from below
  (function(){
    if(window.matchMedia('(prefers-reduced-motion:reduce)').matches) return;
    const box = document.getElementById('embers');
    if(!box) return;
    const N = 22;
    for(let i=0;i<N;i++){
      const e = document.createElement('div');
      const spark = Math.random() < 0.35;
      e.className = 'ember' + (spark ? ' spark' : '');
      const centre = (Math.random()+Math.random())/2;
      e.style.left = (centre*60+20+(Math.random()*20-10))+'%';
      const sz = spark ? 2 : (2+Math.random()*1.5);
      e.style.width = sz+'px';
      e.style.height = sz+'px';
      const dur = 7+Math.random()*8;
      e.style.animationDuration = dur+'s';
      e.style.animationDelay = (-Math.random()*dur)+'s';
      e.style.setProperty('--drift',(Math.random()*36-18).toFixed(0)+'px');
      box.appendChild(e);
    }
  })();

  // PWA navigation
  (function(){
    const isStandalone =
      window.matchMedia('(display-mode:standalone)').matches ||
      window.navigator.standalone === true;
    if(!isStandalone) return;
    document.addEventListener('click',function(e){
      const a = e.target.closest('a[href]');
      if(!a) return;
      const href = a.getAttribute('href');
      if(!href||href.startsWith('#')) return;
      e.preventDefault();
      window.location.href = href;
    });
  })();
</script>
</body>
</html>
